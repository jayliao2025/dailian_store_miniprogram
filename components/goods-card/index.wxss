.goods-card {
  box-sizing: border-box;
  font-size: 24rpx;
}

.goods-card__main {
  display: flex;
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.goods-card__thumb {
  flex-shrink: 0;
  width: 180rpx;
  height: 180rpx;
}

.goods-card__img {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  overflow: hidden;
}

.goods-card__body {
  display: flex;
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
  flex-direction: column;
  justify-content: space-between;
}

.goods-card__upper {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.goods-card__title {
  font-size: 30rpx;
  color: #111827;
  font-weight: 500;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.5;
}

.goods-card__meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.goods-card__tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.goods-card__tag {
  color: #2563eb;
  background: #eff6ff;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  margin: 0 8rpx 8rpx 0;
}

.goods-card__down {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: 16rpx;
}

.goods-card__price-group {
  display: flex;
  align-items: baseline;
}

.goods-card__origin-price {
  white-space: nowrap;
  color: #94a3b8;
  font-size: 22rpx;
  margin-left: 10rpx;
}

.goods-card__buy-btn {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #fff;
  font-size: 24rpx;
  line-height: 1;
}

.spec-for-price {
  font-size: 36rpx;
  white-space: nowrap;
  font-weight: 700;
  color: #ef4444;
  margin: 0;
}

.spec-for-symbol {
  font-size: 24rpx;
}
