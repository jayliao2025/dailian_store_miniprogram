<view style="text-align: center; color: #b9b9b9" wx:if="{{pageLoading}}">
  <t-loading theme="circular" size="40rpx" text="加载中..." inherit-color />
</view>
<view class="home-page-header">
  <view class="search" bind:tap="navToSearchPage">
    <t-search
      t-class-input="t-search__input"
      t-class-input-container="t-search__input-container"
      placeholder="搜索代练套餐 / 区服 / 段位"
      leftIcon=""
      disabled
    >
      <t-icon slot="left-icon" prefix="wr" name="search" size="40rpx" color="#bbb" />
    </t-search>
  </view>
  <view class="swiper-wrap">
    <t-swiper
      wx:if="{{imgSrcs.length > 0}}"
      current="{{current}}"
      autoplay="{{autoplay}}"
      duration="{{duration}}"
      interval="{{interval}}"
      navigation="{{navigation}}"
      imageProps="{{swiperImageProps}}"
      list="{{imgSrcs}}"
      bind:click="navToActivityDetail"
    />
  </view>
</view>
<view class="home-page-container">
  <view class="points-banner" wx:if="{{pointsActivity}}" bind:tap="navToPointsActivity">
    <view>
      <view class="points-banner__title">{{pointsActivity.title}}</view>
      <view class="points-banner__subtitle">{{pointsActivity.subtitle}}</view>
    </view>
    <view class="points-banner__btn">{{pointsActivity.buttonText}}</view>
  </view>

  <view class="section-block" wx:if="{{hotList.length}}">
    <view class="section-head">
      <view>
        <view class="section-title">热销套餐</view>
        <view class="section-subtitle">大家都在买</view>
      </view>
    </view>
    <scroll-view class="hot-scroll" scroll-x enhanced show-scrollbar="false">
      <view class="hot-list">
        <view class="hot-card" wx:for="{{hotList}}" wx:key="spuId" data-spu-id="{{item.spuId}}" bind:tap="navToHotDetail">
          <t-image src="{{item.thumb}}" t-class="hot-card__img" mode="aspectFill" />
          <view class="hot-card__title">{{item.title}}</view>
          <view class="hot-card__meta">已售 {{item.soldCount}}</view>
          <view class="hot-card__price-row">
            <price wr-class="hot-card__price" symbol-class="hot-card__symbol" price="{{item.price}}" />
            <price wr-class="hot-card__origin" price="{{item.originPrice}}" type="delthrough" />
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section-block goods-section">
    <view class="section-head">
      <view>
        <view class="section-title">套餐列表</view>
        <view class="section-subtitle">精选代练套餐</view>
      </view>
    </view>
    <goods-list
      wr-class="goods-list-container"
      goodsList="{{goodsList}}"
      bind:click="goodListClickHandle"
      bind:addcart="goodListAddCartHandle"
    />
    <load-more list-is-empty="{{!goodsList.length}}" status="{{goodsListLoadStatus}}" bind:retry="onReTry" />
  </view>
  <t-toast id="t-toast" />
</view>
