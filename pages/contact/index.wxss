page {
  background: #f5f7fb;
}

.contact-page {
  padding: 24rpx;
}

.contact-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.contact-hero {
  background: linear-gradient(135deg, #eff6ff, #ffffff);
}

.contact-title,
.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
}

.contact-desc,
.section-note,
.tip-item text {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.7;
}

.contact-desc {
  margin-top: 16rpx;
}

.contact-btn {
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #fff;
  font-size: 28rpx;
}

.contact-btn::after {
  border: none;
}

.qr-wrapper {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
}

.qr-image {
  width: 320rpx;
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.section-note {
  margin-top: 16rpx;
  text-align: center;
}

.tip-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
}
